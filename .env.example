# Cho App Trans — environment variables

# === Production（上架必設）===
# Cloudflare Worker URL（部署後貼上，例如 https://choapptrans-api.xxx.workers.dev）
EXPO_PUBLIC_API_BASE_URL=

# 與 Worker 的 API_SECRET 相同（建議設定，防止他人濫用你的 Worker）
EXPO_PUBLIC_API_SECRET=

# OCR.space 金鑰（Worker 被第三方阻擋時，App 會改由手機直連 OCR）
EXPO_PUBLIC_OCR_SPACE_API_KEY=

# === 勿在正式版設定（Key 應只在 Worker）===
# 僅本機開發、且未啟用 Worker 時才用：
# EXPO_PUBLIC_OCR_SPACE_API_KEY=helloworld

# AdMob（正式建置自動用 production 單元，通常不必改）
# EXPO_PUBLIC_ADMOB_REWARDED_ANDROID_UNIT_ID=
