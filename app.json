{
  "expo": {
    "name": "Cho App Trans",
    "slug": "cho-app-trans",
    "version": "1.0.0",
    "owner": "chofong",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "plugins": [
      "expo-dev-client",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7306915590865813~6425491869",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.choapptrans.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "用於拍照並翻譯畫面中的文字。",
        "NSPhotoLibraryUsageDescription": "用於選取照片進行文字翻譯。"
      }
    },
    "android": {
      "package": "com.choapptrans.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "INTERNET"
      ]
    },
    "extra": {
      "translationCostPoints": 3,
      "rewardPerAd": 1,
      "privacyPolicyUrl": "https://loise-cell.github.io/cho-app-trans/privacy-policy.html",
      "supportEmail": "Ls214306@gmail.com",
      "eas": {
        "projectId": "f1ea064e-d1c2-4743-813c-4c268a311cee"
      }
    }
  }
}
